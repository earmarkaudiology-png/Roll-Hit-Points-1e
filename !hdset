// Roll20 Mod Script: Roll HP from character sheet monsterhd and monsterhd_bonus,
// calculate morale_base, copy armorclass to Bar 2, and copy movement to Bar 3.
//
// Command:
//   !hdset
//
// Behavior per selected token:
// - Reads monsterhd and monsterhd_bonus from the represented character
// - Rolls monsterhd d8 + monsterhd_bonus
// - Sets Bar 1 value and max to the new HP result
// - Calculates morale_base as:
//      50% base
//      +5% per HD above 1
//      +1% per positive HP bonus above hit dice
//      capped at 100%
// - Writes morale_base to the represented character sheet
// - Copies armorclass to Bar 2 (no calculation)
// - Copies movement to Bar 3 (no calculation)
// - If armorclass or movement is blank/missing, leaves that bar blank
// - Skips incomplete sheet data silently

(function () {
    'use strict';

    var SCRIPT_NAME = 'SheetHDSet';
    var COMMAND = '!hdset';

    function htmlEscape(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function whisperGM(text) {
        sendChat(SCRIPT_NAME, '/w gm ' + text);
    }

    function toInt(value, fallback) {
        var n = parseInt(value, 10);
        return isNaN(n) ? fallback : n;
    }

    function cleanValue(value) {
        if (value === undefined || value === null) {
            return '';
        }
        return String(value).replace(/^\s+|\s+$/g, '');
    }

    function rollHDTotal(hdCount, bonus) {
        var rolls = [];
        var total = bonus;
        var i, r;

        for (i = 0; i < hdCount; i++) {
            r = randomInteger(8);
            rolls.push(r);
            total += r;
        }

        return {
            total: total,
            rolls: rolls
        };
    }

    function getOrCreateAttr(charId, attrName) {
        var attrs = findObjs({
            _type: 'attribute',
            _characterid: charId,
            name: attrName
        });

        if (attrs && attrs.length) {
            return attrs[0];
        }

        return createObj('attribute', {
            characterid: charId,
            name: attrName,
            current: ''
        });
    }

    function calculateMorale(hdCount, bonus) {
        var morale = 50;
        var extraHpAboveHd = (bonus > 0) ? bonus : 0;

        morale += Math.max(hdCount - 1, 0) * 5;
        morale += extraHpAboveHd;

        if (morale > 100) {
            morale = 100;
        }

        if (morale < 0) {
            morale = 0;
        }

        return morale;
    }

    on('chat:message', function (msg) {
        var results, i, sel, token, tokenName, charId;
        var hdRaw, bonusRaw, hdCount, bonus, rolled, morale, moraleAttr;
        var acRaw, moveRaw, output, lines, formula, detail, updatedAny;

        if (msg.type !== 'api') {
            return;
        }

        if (msg.content.toLowerCase() !== COMMAND) {
            return;
        }

        if (!msg.selected || !msg.selected.length) {
            whisperGM('No tokens selected.');
            return;
        }

        results = [];
        updatedAny = false;

        for (i = 0; i < msg.selected.length; i++) {
            sel = msg.selected[i];

            if (sel._type !== 'graphic') {
                continue;
            }

            token = getObj('graphic', sel._id);
            if (!token) {
                continue;
            }

            tokenName = token.get('name') || ('Token ' + sel._id);
            charId = token.get('represents');

            if (!charId) {
                continue;
            }

            hdRaw = getAttrByName(charId, 'monsterhd');
            bonusRaw = getAttrByName(charId, 'monsterhd_bonus');
            acRaw = cleanValue(getAttrByName(charId, 'armorclass'));
            moveRaw = cleanValue(getAttrByName(charId, 'movement'));

            hdCount = toInt(hdRaw, NaN);
            bonus = toInt(bonusRaw, 0);

            // Bar 2: armor class, no calculation
            token.set('bar2_value', acRaw);
            token.set('bar2_max', '');

            // Bar 3: movement, no calculation
            token.set('bar3_value', moveRaw);
            token.set('bar3_max', '');

            // If HD is not usable, skip HP/morale silently
            if (isNaN(hdCount) || hdCount < 1) {
                continue;
            }

            rolled = rollHDTotal(hdCount, bonus);

            token.set('bar1_value', rolled.total);
            token.set('bar1_max', rolled.total);

            morale = calculateMorale(hdCount, bonus);
            moraleAttr = getOrCreateAttr(charId, 'morale_base');
            moraleAttr.set('current', morale);

            results.push({
                name: tokenName,
                hdCount: hdCount,
                bonus: bonus,
                total: rolled.total,
                rolls: rolled.rolls,
                morale: morale,
                ac: acRaw,
                move: moveRaw
            });

            updatedAny = true;
        }

        if (!updatedAny) {
            whisperGM('No tokens were updated.');
            return;
        }

        output = '<b>Updated selected tokens</b><br>';
        lines = [];

        for (i = 0; i < results.length; i++) {
            formula = results[i].hdCount + 'd8';
            if (results[i].bonus > 0) {
                formula += '+' + results[i].bonus;
            } else if (results[i].bonus < 0) {
                formula += results[i].bonus;
            }

            detail = results[i].rolls.join(' + ');
            if (results[i].bonus > 0) {
                detail += ' + ' + results[i].bonus;
            } else if (results[i].bonus < 0) {
                detail += ' - ' + Math.abs(results[i].bonus);
            }

            lines.push(
                '<b>' + htmlEscape(results[i].name) + '</b>: ' +
                'HP ' + results[i].total +
                ' (<code>' + htmlEscape(formula) + '</code> = <code>' + detail + '</code>)' +
                ' | Morale <b>' + results[i].morale + '%</b>' +
                ' | AC <b>' + htmlEscape(results[i].ac || '') + '</b>' +
                ' | Move <b>' + htmlEscape(results[i].move || '') + '</b>'
            );
        }

        output += lines.join('<br>');
        whisperGM(output);
    });

    on('ready', function () {
        log(SCRIPT_NAME + ' ready. Use !hdset');
    });
}());
