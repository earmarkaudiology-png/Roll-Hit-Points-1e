// Roll20 Mod Script: HD Set
//
// Command:
//   !hdset
//
// Uses sheet attributes:
//   monsterhd
//   monsterhd_bonus
//   armorclass
//   armorclass_override
//   movement
//   movement_override
//   morale_base
//   no_appearing OR number_appearing
//   lair OR percent_in_lair
//
// Writes:
//   Bar 1 = HP (value and max)
//   Bar 2 = AC (value only)
//   Bar 3 = Movement (value only, full text)
//   Morale = updates morale_base, morale, and monstermorale
//
// Notes:
//   - Command remains !hdset
//   - Adds No. Appearing and In Lair rolling/display like the monster manual API
//   - Does not change token bars for appearing/lair; it reports them to GM chat
//   - If no_appearing is non-numeric text such as "See nest composition", it will display nothing for that field

on('ready', function () {
    'use strict';

    var SCRIPT_NAME = 'HDSet';
    var COMMAND = '!hdset';

    var ATTR_HD = 'monsterhd';
    var ATTR_HD_BONUS = 'monsterhd_bonus';

    var ATTR_AC = 'armorclass';
    var ATTR_AC_OVERRIDE = 'armorclass_override';

    var ATTR_MOVE = 'movement';
    var ATTR_MOVE_OVERRIDE = 'movement_override';

    var ATTR_MORALE_BASE = 'morale_base';
    var ATTR_MORALE = 'morale';
    var ATTR_MONSTER_MORALE = 'monstermorale';

    function whisperGM(text) {
        sendChat(SCRIPT_NAME, '/w gm ' + text);
    }

    function escapeHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function hasText(value) {
        return value !== undefined && value !== null && String(value).trim() !== '';
    }

    function trim(value) {
        return String(value || '').replace(/^\s+|\s+$/g, '');
    }

    function toInt(value, fallback) {
        var n = parseInt(value, 10);
        return isNaN(n) ? fallback : n;
    }

    function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
    }

    function formatBonus(n) {
        if (!n) return '';
        return (n > 0 ? '+' : '') + n;
    }

    function normalizeDashText(value) {
        return String(value || '').replace(/[–—−]/g, '-').trim();
    }

    function findAttribute(characterId, attrName) {
        return findObjs({
            type: 'attribute',
            characterid: characterId,
            name: attrName
        })[0];
    }

    function getOrCreateAttribute(characterId, attrName, currentValue, maxValue) {
        var attr = findAttribute(characterId, attrName);

        if (!attr) {
            attr = createObj('attribute', {
                characterid: characterId,
                name: attrName,
                current: currentValue,
                max: maxValue
            });
        }

        return attr;
    }

    function setAttrWithMax(characterId, attrName, currentValue, maxValue) {
        var attr = getOrCreateAttribute(characterId, attrName, currentValue, maxValue);
        attr.set({
            current: currentValue,
            max: maxValue
        });
        return attr;
    }

    function setMoraleAttributes(characterId, value) {
        setAttrWithMax(characterId, ATTR_MORALE_BASE, value, value);
        setAttrWithMax(characterId, ATTR_MORALE, value, value);
        setAttrWithMax(characterId, ATTR_MONSTER_MORALE, value, value);
    }

    function parseMonsterHD(hdRaw, bonusRaw) {
        var hdText = String(hdRaw || '').replace(/\s+/g, '').toLowerCase();
        var sheetBonus = toInt(bonusRaw, 0);
        var m, dice, inlineBonus, totalBonus;

        if (!hdText) return null;

        hdText = hdText.replace(/^hd/, '');

        if (/^\d+$/.test(hdText)) {
            dice = parseInt(hdText, 10);
            return {
                type: 'normal',
                dice: dice,
                bonus: sheetBonus,
                label: dice + 'd8' + formatBonus(sheetBonus),
                fullHD: dice
            };
        }

        m = hdText.match(/^(\d+)([+-]\d+)$/);
        if (m) {
            dice = parseInt(m[1], 10);
            inlineBonus = parseInt(m[2], 10);
            totalBonus = inlineBonus + sheetBonus;

            return {
                type: 'normal',
                dice: dice,
                bonus: totalBonus,
                label: dice + 'd8' + formatBonus(totalBonus),
                fullHD: dice
            };
        }

        if (hdText === '1/2') {
            return {
                type: 'fraction',
                die: 4,
                bonus: sheetBonus,
                label: '1d4' + formatBonus(sheetBonus),
                fullHD: 0
            };
        }

        if (hdText === '1/4') {
            return {
                type: 'fraction',
                die: 2,
                bonus: sheetBonus,
                label: '1d2' + formatBonus(sheetBonus),
                fullHD: 0
            };
        }

        return null;
    }

    function rollParsedHD(parsed) {
        var total = parsed.bonus || 0;
        var rolls = [];
        var i, r;

        if (parsed.type === 'normal') {
            for (i = 0; i < parsed.dice; i++) {
                r = randomInteger(8);
                rolls.push(r);
                total += r;
            }
        } else if (parsed.type === 'fraction') {
            r = randomInteger(parsed.die);
            rolls.push(r);
            total += r;
        } else {
            return null;
        }

        if (total < 1) total = 1;

        return {
            total: total,
            rolls: rolls
        };
    }

    function calculateBaseMorale(parsedHD) {
        var morale = 50;

        if (parsedHD.fullHD > 1) {
            morale += (parsedHD.fullHD - 1) * 5;
        }

        return clamp(morale, 1, 100);
    }

    function chooseACValue(charId, token) {
        var overrideValue = getAttrByName(charId, ATTR_AC_OVERRIDE);
        var baseValue = getAttrByName(charId, ATTR_AC);
        var tokenValue = token.get('bar2_value');

        if (hasText(overrideValue)) return String(overrideValue);
        if (hasText(tokenValue)) return String(tokenValue);
        if (hasText(baseValue)) return String(baseValue);
        return '';
    }

    function chooseMoveValue(charId, token) {
        var overrideValue = getAttrByName(charId, ATTR_MOVE_OVERRIDE);
        var baseValue = getAttrByName(charId, ATTR_MOVE);
        var tokenValue = token.get('bar3_value');

        if (hasText(overrideValue)) return String(overrideValue);
        if (hasText(tokenValue)) return String(tokenValue);
        if (hasText(baseValue)) return String(baseValue);
        return '';
    }

    function rollSimpleRange(textValue) {
        var t = normalizeDashText(textValue);
        var m, lo, hi, tmp;

        if (!t) return null;
        if (/^nil$/i.test(t)) return { label: t, rolled: 0, kind: 'nil' };

        m = t.match(/^(\d+)\s*-\s*(\d+)/);
        if (m) {
            lo = parseInt(m[1], 10);
            hi = parseInt(m[2], 10);

            if (hi < lo) {
                tmp = lo;
                lo = hi;
                hi = tmp;
            }

            return {
                label: lo + '-' + hi,
                rolled: randomInteger(hi - lo + 1) + lo - 1,
                kind: 'range'
            };
        }

        m = t.match(/^(\d+)/);
        if (m) {
            return {
                label: m[1],
                rolled: parseInt(m[1], 10),
                kind: 'fixed'
            };
        }

        return null;
    }

    function rollLairChance(textValue) {
        var t = normalizeDashText(textValue).trim();
        var m, pct, d100;

        if (!t || /^nil$/i.test(t)) {
            return {
                label: '0%',
                rolled: 0,
                isInLair: false,
                kind: 'nil'
            };
        }

        m = t.match(/(\d+)\s*%?/);
        if (!m) return null;

        pct = Math.max(0, Math.min(100, parseInt(m[1], 10)));
        d100 = randomInteger(100);

        return {
            label: pct + '%',
            rolled: d100,
            isInLair: d100 <= pct,
            kind: 'percent'
        };
    }

    on('chat:message', function (msg) {
        var i, sel, token, tokenName, charId;
        var hdRaw, bonusRaw;
        var acValue, moveValue;
        var parsedHD, rolled, moraleValue;
        var noAppearingValue, lairValue, rolledAppearing, rolledLair;
        var updateObj;
        var errors = [];
        var successes = [];

        if (msg.type !== 'api') return;
        if (!msg.content) return;
        if (String(msg.content).trim().toLowerCase() !== COMMAND) return;

        if (!msg.selected || !msg.selected.length) {
            whisperGM('<div style="padding:8px;border:1px solid #900;background:#220000;color:#fff;border-radius:6px;">No tokens selected.</div>');
            return;
        }

        for (i = 0; i < msg.selected.length; i++) {
            sel = msg.selected[i];

            if (sel._type !== 'graphic') continue;

            token = getObj('graphic', sel._id);
            if (!token) {
                errors.push('Selected object ' + sel._id + ' could not be read as a token.');
                continue;
            }

            tokenName = token.get('name') || ('Token ' + sel._id);
            charId = token.get('represents');

            if (!charId) {
                errors.push('<b>' + escapeHtml(tokenName) + '</b>: no represented character.');
                continue;
            }

            hdRaw = getAttrByName(charId, ATTR_HD);
            bonusRaw = getAttrByName(charId, ATTR_HD_BONUS);

            acValue = chooseACValue(charId, token);
            moveValue = chooseMoveValue(charId, token);

            noAppearingValue = getAttrByName(charId, 'no_appearing') || getAttrByName(charId, 'number_appearing');
            lairValue = getAttrByName(charId, 'lair') || getAttrByName(charId, 'percent_in_lair');

            rolledAppearing = rollSimpleRange(noAppearingValue);
            rolledLair = rollLairChance(lairValue);

            parsedHD = parseMonsterHD(hdRaw, bonusRaw);

            if (!parsedHD) {
                errors.push(
                    '<b>' + escapeHtml(tokenName) + '</b>: bad HD. ' +
                    'monsterhd=<code>' + escapeHtml(hdRaw) + '</code>, ' +
                    'monsterhd_bonus=<code>' + escapeHtml(bonusRaw) + '</code>'
                );
                continue;
            }

            rolled = rollParsedHD(parsedHD);
            if (!rolled) {
                errors.push('<b>' + escapeHtml(tokenName) + '</b>: roll failed.');
                continue;
            }

            moraleValue = calculateBaseMorale(parsedHD);
            setMoraleAttributes(charId, moraleValue);

            updateObj = {
                bar1_value: rolled.total,
                bar1_max: rolled.total
            };

            if (hasText(acValue)) {
                updateObj.bar2_value = acValue;
            }

            if (hasText(moveValue)) {
                updateObj.bar3_value = moveValue;
            }

            token.set(updateObj);

            successes.push(
                '<b>' + escapeHtml(tokenName) + '</b>: ' +
                escapeHtml(parsedHD.label) + ' → HP <b>' + escapeHtml(rolled.total) + '</b>' +
                (hasText(acValue) ? ', AC ' + escapeHtml(acValue) : '') +
                (hasText(moveValue) ? ', MV ' + escapeHtml(moveValue) : '') +
                (rolledAppearing ? ', No. Appearing ' + escapeHtml(rolledAppearing.label) + ' → <b>' + escapeHtml(rolledAppearing.rolled) + '</b>' : '') +
                (rolledLair ? ', In Lair ' + escapeHtml(rolledLair.label) + ' → <b>' + escapeHtml(rolledLair.rolled) + '</b> (' + escapeHtml(rolledLair.isInLair ? 'Yes' : 'No') + ')' : '') +
                ', Morale ' + escapeHtml(moraleValue) + '%'
            );
        }

        if (successes.length) {
            whisperGM(
                '<div style="padding:8px;border:1px solid #264b1f;background:#10240d;color:#fff;border-radius:6px;">' +
                '<b>HD Updated</b><br>' +
                '<span style="color:#bbb;">HP • AC • movement • No. Appearing • In Lair • morale</span><br>' +
                successes.join('<br>') +
                '</div>'
            );
        }

        if (errors.length) {
            whisperGM(
                '<div style="padding:8px;border:1px solid #900;background:#220000;color:#fff;border-radius:6px;">' +
                '<b>HD Errors</b><br>' +
                errors.join('<br>') +
                '</div>'
            );
        }
    });

    log(SCRIPT_NAME + ' ready. Use !hdset');
});
